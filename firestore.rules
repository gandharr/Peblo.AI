rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // User Rules
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    // Note Rules
    match /notes/{noteId} {
      
      function isValidNote(note) {
        return note.ownerId == request.auth.uid
          && note.title is string && note.title.size() <= 200
          && note.content is string && note.content.size() <= 100000
          && note.tags is list && note.tags.size() <= 20
          && note.isPublic is bool
          && note.shareId is string && note.shareId.size() <= 128
          && (note.get('summary', null) == null || (note.summary is string && note.summary.size() <= 2500))
          && (note.get('actionItems', null) == null || (note.actionItems is list && note.actionItems.size() <= 50));
      }

      // Read: Owner can read any. Public notes can be read by anyone if they have the shareId.
      // Note: List operation is restricted to owner only. Single GET can be public.
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      
      allow get: if isOwner(resource.data.ownerId) || (resource.data.get('isPublic', false) == true);

      allow create: if isOwner(incoming().ownerId) 
        && isValidNote(incoming())
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time
        && incoming().keys().hasAll(['ownerId', 'title', 'content', 'tags', 'isPublic', 'shareId', 'createdAt', 'updatedAt'])
        && incoming().keys().size() >= 8 && incoming().keys().size() <= 10;

      allow update: if isOwner(existing().ownerId)
        && isValidNote(incoming())
        && incoming().ownerId == existing().ownerId
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time
        && (
          // Action: Edit content or metadata
          incoming().diff(existing()).affectedKeys().hasOnly(['title', 'content', 'tags', 'isPublic', 'updatedAt']) ||
          // Action: AI Insights generation
          incoming().diff(existing()).affectedKeys().hasOnly(['summary', 'actionItems', 'title', 'updatedAt'])
        );

      allow delete: if isOwner(resource.data.ownerId);
    }
  }
}
